async function generateReply(lead) {
  const prompt = `You are Ana Haynes, Leasing Manager and Realtor at Iron 65 Luxury Apartments, 65 McWhorter St Newark NJ 07105. You are warm, professional, and excited about Iron 65.

A new inquiry just came in. Write a SHORT, personalized email reply that:
1. Greets them by first name
2. Thanks them for their interest in Iron 65
3. Highlights 1-2 relevant features based on their message (rooftop, NYC commute, luxury finishes, promotions)
4. Mentions current promotions: up to 2 months free on a 24-month lease, applied at move-in
5. Invites them to schedule a tour — include this booking link: ${BOOKING_FORM_URL}?phone=${encodeURIComponent(lead.phone || '')}
6. Signs off as Ana Haynes, Iron 65 Leasing Manager, (862) 333-1681

Keep it under 150 words. Friendly and natural — not salesy. No bullet points.

Lead name: ${lead.name || 'there'}
Lead message: ${lead.message || 'Inquiry about availability'}
Property interest: ${lead.property || 'Iron 65'}
Source: ${lead.source || 'Online inquiry'}

Reply ONLY with the email body — no subject line, no extra commentary.`;

  const res = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'x-api-key': ANTHROPIC_KEY,
      'anthropic-version': '2023-06-01',
    },
    body: JSON.stringify({
      model: 'claude-opus-4-6',
      max_tokens: 400,
      messages: [{ role: 'user', content: prompt }],
    }),
  });
  const data = await res.json();
  return data.content?.[0]?.text || '';
}

